# 複製為 .env.local 並填入(僅本機使用,已被 .gitignore 排除)。
# 給 scripts/export_terms.py 使用,把雲端詞庫匯回 dict/terms.json。
# service_role 金鑰位置:Supabase → Project Settings → API → service_role(secret)
# ⚠ service_role 可繞過 RLS,絕對不可放進前端或 commit。
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY
